{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/freight", "destination": "api/freight.py" },
    { "source": "/api/chat", "destination": "api/chat.py" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
